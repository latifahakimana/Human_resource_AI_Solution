generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb" // Change to "mongodb" if using Mongo
  url      = env("DATABASE_URL")
}

model TalentProfile {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  firstName    String
  lastName     String
  email        String   @unique
  headline     String
  bio          String?
  location     String
  skills       Json     
  languages    Json?    
  experience   Json     
  education    Json     
  certifications Json?  
  projects     Json     
  availability Json     
  socialLinks  Json?    
}